{
	"name": "astro-ai-robots-txt-monorepo",
	"version": "0.0.1",
	"license": "MIT",
	"description": "Block AI scrapers in the `robots.txt` for your Astro site",
	"author": "delucis",
	"type": "module",
	"packageManager": "pnpm@10.34.4+sha512.8768be55200ae3f2226b6527fcca2687e14bc4e5f12d7721a0f25da3df47915177058648db4177baf348120fa0ba2752d8d8d93f6beaf1fe64ae18da8de961af",
	"private": true,
	"homepage": "https://delucis.github.io/astro-ai-robots-txt/",
	"repository": {
		"type": "git",
		"url": "https://github.com/delucis/astro-ai-robots-txt.git"
	},
	"bugs": "https://github.com/delucis/astro-ai-robots-txt/issues",
	"devDependencies": {
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0"
	},
	"scripts": {
		"ci-version": "changeset version && pnpm install --no-frozen-lockfile",
		"ci-publish": "changeset publish",
		"test": "pnpm -F ./docs build && (if [ ! -f docs/dist/robots.txt ]; then echo 'Missing robots.txt'; exit 1; fi)"
	}
}
